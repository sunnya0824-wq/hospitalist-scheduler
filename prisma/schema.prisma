// Hospitalist Scheduler — Prisma schema
// PostgreSQL datasource. Run `prisma migrate dev` locally and
// `prisma migrate deploy` in production (handled by the start script).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ShiftType {
  ROUNDER
  ADMIN
  NIGHT_ADMIT_1
  NIGHT_ADMIT_2
}

enum Hospital {
  MAIN
  CARSON
  EATON
  CLINTON
}

enum ShiftPreference {
  MORE
  FEWER
  NEUTRAL
}

enum AvailabilityType {
  UNAVAILABLE
  PREFERRED
}

enum ScheduleStatus {
  DRAFT
  GENERATED
  PUBLISHED
}

model Physician {
  id             String          @id @default(cuid())
  fullName       String
  active         Boolean         @default(true)
  desiredShifts  Int             @default(14)
  minShifts      Int             @default(0)
  maxShifts      Int             @default(20)
  minRounding    Int             @default(0)
  maxRounding    Int             @default(20)
  minNights      Int             @default(0)
  maxNights      Int             @default(8)
  minAdmin       Int             @default(0)
  maxAdmin       Int             @default(8)
  shiftPreference ShiftPreference @default(NEUTRAL)
  nightEligible  Boolean         @default(true)
  adminEligible  Boolean         @default(true)
  canWorkCarson  Boolean         @default(false)
  canWorkEaton   Boolean         @default(false)
  canWorkClinton Boolean         @default(false)
  // Fractional appointment (1.0 = full time). Scales the auto-computed target.
  fteMultiplier      Decimal     @default(1.0)
  // Explicit per-month shift target. Null → round(monthlyAvg * fteMultiplier).
  monthlyShiftTarget Int?
  // Hard cap on consecutive working days across all hospitals.
  maxConsecutiveDays Int         @default(7)
  // Opaque token for the personal ICS calendar feed.
  icsToken       String          @unique @default(cuid())
  notes          String?

  // --- Soft scheduling preferences (strongly weighted, never hard) ---
  // Direction preferences. prefersX and avoidsX are mutually exclusive
  // (enforced in the API and UI); both false = neutral.
  prefersNights      Boolean @default(false)
  avoidsNights       Boolean @default(false)
  prefersWeekends    Boolean @default(false)
  avoidsWeekends     Boolean @default(false)
  prefersDayAdmit    Boolean @default(false)
  avoidsDayAdmit     Boolean @default(false)
  // Per-weekday avoid map: { "0": true, ... } where 0 = Sunday … 6 = Saturday.
  avoidWeekdays  Json    @default("{}")
  // Soft monthly caps (null = no cap). Scheduler avoids exceeding unless forced.
  maxNightsPerMonth   Int?
  maxWeekendsPerMonth Int?

  availability    PhysicianAvailability[]
  preferences     PhysicianPreference[]
  assignments     ShiftAssignment[]
  timeOffRequests TimeOffRequest[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model TimeOffRequest {
  id          String    @id @default(cuid())
  physician   Physician @relation(fields: [physicianId], references: [id], onDelete: Cascade)
  physicianId String
  date        DateTime // date-only, midnight UTC of the requested day off
  note        String?
  createdAt   DateTime  @default(now())

  @@unique([physicianId, date])
  @@index([physicianId])
  @@index([date])
}

model ScheduleMonth {
  id           String           @id @default(cuid())
  year         Int
  month        Int // 1-12
  status       ScheduleStatus   @default(DRAFT)
  rounderCount     Int          @default(10) // 1-20 ROUNDER slots/day
  dayAdmitCount    Int          @default(1)  // 0-3 ADMIN slots/day
  nightAdmit1Count Int          @default(1)  // 0-2 NIGHT_ADMIT_1 slots/day
  nightAdmit2Count Int          @default(1)  // 0-2 NIGHT_ADMIT_2 slots/day
  carsonRounderCount  Int       @default(0)  // ROUNDER slots/day at Sparrow Carson
  eatonRounderCount   Int       @default(0)  // ROUNDER slots/day at Sparrow Eaton
  clintonRounderCount Int       @default(0)  // ROUNDER slots/day at Sparrow Clinton
  createdAt    DateTime         @default(now())
  generatedAt  DateTime?

  assignments  ShiftAssignment[]
  runs         ScheduleGenerationRun[]

  @@unique([year, month])
}

model ShiftAssignment {
  id              String        @id @default(cuid())
  scheduleMonth   ScheduleMonth @relation(fields: [scheduleMonthId], references: [id], onDelete: Cascade)
  scheduleMonthId String

  date            DateTime // the calendar day the shift starts (date-only, midnight UTC)
  endDate         DateTime // the calendar day the shift ends (night shifts cross midnight)
  shiftType       ShiftType
  hospital        Hospital      @default(MAIN)
  rounderIndex    Int? // 1-10 for ROUNDER slots
  startTime       String // e.g. "07:00"
  endTime         String // e.g. "17:00"

  physician       Physician?    @relation(fields: [physicianId], references: [id], onDelete: SetNull)
  physicianId     String?

  isManual        Boolean       @default(false)
  isLocked        Boolean       @default(false)
  isAutoGenerated Boolean       @default(false)
  warnings        String[]      @default([])

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([scheduleMonthId])
  @@index([date])
}

model PhysicianAvailability {
  id          String           @id @default(cuid())
  physician   Physician        @relation(fields: [physicianId], references: [id], onDelete: Cascade)
  physicianId String
  date        DateTime
  type        AvailabilityType

  @@unique([physicianId, date, type])
  @@index([physicianId])
}

// Optional per-month overrides. Collapses cleanly into Physician defaults
// when no override row exists for a given month.
model PhysicianPreference {
  id            String   @id @default(cuid())
  physician     Physician @relation(fields: [physicianId], references: [id], onDelete: Cascade)
  physicianId   String
  year          Int
  month         Int
  desiredShifts Int?
  minShifts     Int?
  maxShifts     Int?
  notes         String?

  @@unique([physicianId, year, month])
}

model ScheduleGenerationRun {
  id              String        @id @default(cuid())
  scheduleMonth   ScheduleMonth @relation(fields: [scheduleMonthId], references: [id], onDelete: Cascade)
  scheduleMonthId String
  startedAt       DateTime      @default(now())
  finishedAt      DateTime?
  success         Boolean       @default(false)
  warnings        String[]      @default([])
  summary         Json?

  @@index([scheduleMonthId])
}
